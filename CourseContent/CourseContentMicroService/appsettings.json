{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=MicroServiceCourseContentDb;Trusted_Connection=true;TrustServerCertificate=true"
  },
  "FileUpload": {
    "MaxVideoFileSizeMB": 2048,
    "MaxPdfFileSizeMB": 100,
    "AllowedVideoExtensions": [ ".mp4", ".avi", ".mov" ],
    "AllowedDocumentExtensions": [ ".pdf" ],
    "UploadPath": "wwwroot/uploads/lessons",
    "BaseUrl": "https://localhost:7272/uploads/lessons"
  }
}
